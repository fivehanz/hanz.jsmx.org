#!/bin/sh

# PROVIDE: litestream
# REQUIRE: NETWORKING
# KEYWORD: shutdown

. /etc/rc.subr

name="litestream"
rcvar="litestream_enable"

: ${litestream_enable:=NO}
: ${litestream_config:=/usr/local/etc/litestream.yml}

pidfile="/var/run/litestream.pid"
procname="/usr/local/bin/litestream"

command="/usr/sbin/daemon"
command_args="-u www -p ${pidfile} -P -f \
    -o /var/log/litestream.log -m 3 \
    /usr/local/www/wagtail/prod/freebsd/scripts/litestream.sh"

load_rc_config $name

run_rc_command "$1"
