upstream wagtail {
    server unix:/var/run/wagtail.sock;
    keepalive 8;
}

proxy_cache_path /var/cache/nginx/wagtail
    keys_zone=wagtail_cache:16m
    max_size=128m
    inactive=60m;

server {
    listen 80;
    listen [::]:80;
    server_name hanz.jsmx.org;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name hanz.jsmx.org;

    ssl_certificate     /usr/local/etc/ssl/cf-origin.pem;
    ssl_certificate_key /usr/local/etc/ssl/cf-origin.key;

    # root /usr/local/www/wagtail/staticfiles;

    # upload protection
    client_max_body_size 16m;
    client_body_timeout 10s;
    client_header_timeout 10s;
    send_timeout 15s;

    # security headers
    # add_header Strict-Transport-Security "max-age=31536000" always;
    add_header X-Frame-Options SAMEORIGIN always;
    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy strict-origin-when-cross-origin always;

    location /static/ {
        alias /usr/local/www/wagtail/staticfiles/;
        expires 30d;
        add_header Cache-Control "public, immutable";
        access_log off;
        sendfile on;
    }

    location /media/ {
        alias /usr/local/www/wagtail/media/;
        expires 7d;
        add_header Cache-Control "public";
        access_log off;
        sendfile on;
    }

    # optional: restrict admin to specific IP
    # location /admin/ {
    #     allow YOUR.IP.ADDRESS;
    #     deny all;
    # }

    location / {

        proxy_pass http://wagtail;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Real-IP $remote_addr;

        proxy_buffering on;

        proxy_cache wagtail_cache;
        proxy_cache_valid 200 5s;
        proxy_cache_valid 404 1s;

        proxy_cache_bypass $cookie_sessionid;
        proxy_no_cache $cookie_sessionid;

        proxy_cache_bypass $cookie_csrftoken;
        proxy_no_cache $cookie_csrftoken;

        proxy_cache_bypass $http_authorization;
        proxy_no_cache $http_authorization;

        add_header X-Server-Cache $upstream_cache_status;
    }
}